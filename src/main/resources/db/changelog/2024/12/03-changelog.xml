<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.30.xsd" objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <property global="false" name="id" value="1734018350594"/>
    <property global="false" name="author" value="Ziedelth"/>

    <changeSet id="${id}-1" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="member" columnName="identifier"/>
            </not>
        </preConditions>

        <addColumn tableName="member">
            <column name="identifier" type="VARCHAR(255)"/>
        </addColumn>
    </changeSet>

    <changeSet id="${id}-2" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <uniqueConstraintExists constraintName="uc_member_identifier" tableName="member"/>
            </not>
        </preConditions>

        <addUniqueConstraint columnNames="identifier" constraintName="uc_member_identifier" tableName="member"/>
    </changeSet>

    <changeSet id="${id}-3" author="${author}">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="member" columnName="username"/>
        </preConditions>

        <dropNotNullConstraint columnDataType="varchar(255)" columnName="username" tableName="member"/>
    </changeSet>

    <changeSet id="${id}-4" author="${author}">
        <sql>
            UPDATE member SET identifier = username, username = NULL
            WHERE username != 'admin';
        </sql>
    </changeSet>
</databaseChangeLog>
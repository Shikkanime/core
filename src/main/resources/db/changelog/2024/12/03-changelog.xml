<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.30.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <property global="false" name="id" value="1734102112128"/>
    <property global="false" name="author" value="Ziedelth"/>

    <changeSet id="${id}-1" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="episode_platform"/>
            </not>
        </preConditions>

        <createTable tableName="episode_platform">
            <column name="uuid" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_episode_platform"/>
            </column>
            <column name="mapping_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="anime_platform_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="platform_id" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>

    <changeSet id="${id}-2" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_EPISODE_PLATFORM_ON_ANIME_PLATFORM_UUID"/>
            </not>
        </preConditions>

        <addForeignKeyConstraint baseColumnNames="anime_platform_uuid" baseTableName="episode_platform"
                                 constraintName="FK_EPISODE_PLATFORM_ON_ANIME_PLATFORM_UUID" referencedColumnNames="uuid"
                                 referencedTableName="anime_platform"/>
    </changeSet>

    <changeSet id="${id}-3" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="FK_EPISODE_PLATFORM_ON_PLATFORM_ID"/>
            </not>
        </preConditions>

        <addForeignKeyConstraint baseColumnNames="mapping_uuid" baseTableName="episode_platform"
                                 constraintName="FK_EPISODE_PLATFORM_ON_MAPPING_UUID" referencedColumnNames="uuid"
                                 referencedTableName="episode_mapping"/>
    </changeSet>
</databaseChangeLog>
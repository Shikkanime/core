<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <property global="false" name="id" value="1715803569694"/>
    <property global="false" name="author" value="Ziedelth"/>

    <changeSet id="${id}-1" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="calendar_release"/>
            </not>
        </preConditions>

        <createTable tableName="calendar_release">
            <column name="uuid" type="UUID">
                <constraints nullable="false" primaryKey="true" primaryKeyName="pk_calendar_release"/>
            </column>
            <column name="release_date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="release_time" type="TIME"/>
            <column name="platform" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="anime" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="season" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="episode_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="number" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="lang_type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
        </createTable>
    </changeSet>
</databaseChangeLog>
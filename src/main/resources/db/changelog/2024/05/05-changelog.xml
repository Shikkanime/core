<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.27.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <property global="false" name="id" value="1715712523873"/>
    <property global="false" name="author" value="Ziedelth"/>

    <changeSet id="${id}-1" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="anime_genre"/>
            </not>
        </preConditions>

        <createTable tableName="anime_genre">
            <column name="anime_uuid" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="genres" type="VARCHAR(255)"/>
        </createTable>
    </changeSet>

    <changeSet id="${id}-2" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <foreignKeyConstraintExists foreignKeyName="fk_anime_genre_on_anime"
                                            foreignKeyTableName="anime_genre"/>
            </not>
        </preConditions>

        <addForeignKeyConstraint baseColumnNames="anime_uuid" baseTableName="anime_genre"
                                 constraintName="fk_anime_genre_on_anime" referencedColumnNames="uuid"
                                 referencedTableName="anime"/>
    </changeSet>
</databaseChangeLog>
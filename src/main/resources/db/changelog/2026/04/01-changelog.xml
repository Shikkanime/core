<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                   xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
                   xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                   https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
    <property global="false" name="id" value="1775668864036"/>
    <property global="false" name="author" value="Ziedelth"/>

    <changeSet id="${id}-1" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="episode_mapping" columnName="simulcast_uuid"/>
            </not>
        </preConditions>

        <addColumn tableName="episode_mapping">
            <column name="simulcast_uuid" type="UUID">
                <constraints foreignKeyName="fk_episode_mapping_simulcast_uuid" referencedTableName="simulcast"
                             referencedColumnNames="uuid"/>
            </column>
        </addColumn>

        <createIndex tableName="episode_mapping" indexName="idx_episode_mapping_simulcast_uuid">
            <column name="simulcast_uuid"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>

<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.26.xsd"
        objectQuotingStrategy="QUOTE_ONLY_RESERVED_WORDS">
    <property global="false" name="id" value="1782380323698"/>
    <property global="false" name="author" value="Ziedelth"/>

    <changeSet id="${id}-1" author="${author}">
        <preConditions onFail="MARK_RAN">
            <columnExists tableName="anime_platform" columnName="last_validate_date_time"/>
        </preConditions>

        <renameColumn tableName="anime_platform" oldColumnName="last_validate_date_time" newColumnName="last_update_date_time"/>
    </changeSet>

    <changeSet id="${id}-2" author="${author}">
        <preConditions onFail="MARK_RAN">
            <not>
                <columnExists tableName="anime_platform" columnName="available"/>
            </not>
        </preConditions>

        <addColumn tableName="anime_platform">
            <column name="available" type="boolean" defaultValue="true">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>